{
  "name": "twitter",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx serve -s dist/twitter/browser -l tcp://0.0.0.0:$PORT",
    "start:dev": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:static": "ng build --configuration production",
    "build:static:root": "ng build --configuration production --base-href /",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@microsoft/signalr": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
